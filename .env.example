# Copy this file to .env and fill in the values.
# .env is gitignored — never commit actual secrets.

# Backend (leapify-console worker URL).
# Production: wrangler secret put LEAPIFY_API_URL
# Local dev:  add to .env and .dev.vars
LEAPIFY_API_URL=

# Cloudflare Turnstile site key (visible to client — not a secret).
# Test key (always passes): 1x00000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=
