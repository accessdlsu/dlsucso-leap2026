{
  "name": "dlsucso-leap2026",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "postinstall": "npm run setup-git-filters",
    "setup-git-filters": "node scripts/setup-git-filters.js",
    "dev": "cross-env CLOUDFLARE_ENV=lh vite --mode lh",
    "build": "npm run cf-typegen && tsc -b && vite build",
    "build:staging": "npm run cf-typegen && tsc -b && cross-env CLOUDFLARE_ENV=staging vite build --mode staging",
    "build:local": "npm run cf-typegen && tsc -b && cross-env CLOUDFLARE_ENV=lh vite build --mode lh",
    "preview": "npm run build:staging && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "deploy:staging": "npm run build:staging && wrangler deploy --env staging",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4",
    "framer-motion": "^12",
    "leapify": "npm:@access-dlsu/leapify@latest",
    "lucide-react": "^1",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1",
    "@cloudflare/workers-types": "^4",
    "@eslint/js": "^10",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "autoprefixer": "^10",
    "cross-env": "^10",
    "eslint": "^10",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-react-refresh": "^0",
    "globals": "^17",
    "jsonc-parser": "^3",
    "postcss": "^8",
    "tailwindcss": "^4",
    "terser": "^5",
    "typescript": "^6",
    "typescript-eslint": "^8",
    "vite": "^8",
    "wrangler": "^4"
  }
}