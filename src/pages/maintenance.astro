import Layout from "../layouts/Layout.astro";

const fireflies = Array.from({ length: 16 }, (_, i) => ({
  id: i,
  x: ((i * 17.3 + (i % 3) * 29) % 94) + 3,
  y: ((i * 11.7 + (i % 5) * 13) % 55) + 5,
  size: 2 + (i % 3),
  delay: (i * 0.61) % 7,
  dur: 3.5 + (i % 5) * 0.6,
}));

const shapes = Array.from({ length: 8 }, (_, i) => ({
  id: i,
  x: 5 + ((i * 12.5 + (i % 2) * 4) % 90),
  y: 8 + ((i * 9.3 + (i % 3) * 7) % 75),
  size: 30 + (i % 4) * 20,
  delay: (i * 1.2) % 6,
  dur: 10 + (i % 3) * 5,
  type: i % 3,
  rotation: (i * 52) % 360,
}));

const bgBuildings = [
  { x: 30, w: 70, y: 270 },
  { x: 150, w: 70, y: 280 },
  { x: 280, w: 70, y: 260 },
  { x: 410, w: 70, y: 275 },
  { x: 530, w: 70, y: 255 },
  { x: 820, w: 70, y: 265 },
  { x: 940, w: 70, y: 285 },
  { x: 1070, w: 70, y: 270 },
  { x: 1210, w: 70, y: 260 },
  { x: 1320, w: 70, y: 280 },
];

const midBuildings = [
  { x: 10, w: 70, y: 230 },
  { x: 110, w: 70, y: 215 },
  { x: 230, w: 70, y: 225 },
  { x: 350, w: 70, y: 210 },
  { x: 480, w: 70, y: 205 },
  { x: 800, w: 70, y: 220 },
  { x: 910, w: 70, y: 210 },
  { x: 1040, w: 70, y: 225 },
  { x: 1170, w: 70, y: 215 },
  { x: 1290, w: 70, y: 230 },
];

const fgBuildings = [
  { x: 0, w: 70, y: 200 },
  { x: 100, w: 70, y: 185 },
  { x: 260, w: 70, y: 195 },
  { x: 420, w: 70, y: 175 },
  { x: 560, w: 70, y: 165 },
  { x: 700, w: 70, y: 180 },
  { x: 840, w: 70, y: 170 },
  { x: 980, w: 70, y: 190 },
  { x: 1120, w: 70, y: 175 },
  { x: 1280, w: 70, y: 195 },
];

const getRackSlots = (
  b: { x: number; w: number; y: number },
  step = 10,
  slotH = 3,
) => {
  const slots = [];
  const startY = b.y + 8;
  const endY = 310; // Ground line
  const rackW = b.w - 18;
  const rackX = b.x + 9;

  for (let cy = startY; cy < endY - 6; cy += step) {
    const hasLight = (cy + b.x) % 11 < 3;
    const lightGap = 12; // Blank space offset for indicator LED
    slots.push({
      x: hasLight ? rackX + lightGap : rackX,
      y: cy,
      w: hasLight ? rackW - lightGap : rackW,
      h: slotH,
      hasLight,
      lightX: rackX + 4,
      lightColor: (cy + b.x) % 2 === 0 ? "#10b981" : "#f59e0b",
    });
  }
  return slots;
};
