</style>

<script>
  // Dev bypass bar: shown when the worker sets _dev=1 cookie (local dev only)
  const isDev = document.cookie.indexOf("_dev=1") !== -1;
  if (isDev) {
    const bar = document.getElementById("dev-bypass");
    if (bar) bar.style.display = "flex";

  }

  // Admin bypass bar: shown when worker sets _admin_gate=1 cookie (admin user, gate active)
  if (document.cookie.indexOf("_admin_gate=1") !== -1) {
    const bar = document.getElementById("admin-bypass");
    if (bar) bar.style.display = "flex";
  }

  // Non-admin notice: shown when worker sets _non_admin=1 cookie (logged in but not admin)
  if (document.cookie.indexOf("_non_admin=1") !== -1) {
    const bar = document.getElementById("non-admin-notice");
    if (bar) bar.style.display = "flex";
  }

  // Auth bar: shown when not logged in (no admin/non-admin cookie) and not in dev mode
  const hasAdminCookie = document.cookie.indexOf("_admin_gate=1") !== -1;
  const hasNonAdminCookie = document.cookie.indexOf("_non_admin=1") !== -1;
  if (!isDev && !hasAdminCookie && !hasNonAdminCookie) {
    const bar = document.getElementById("auth-bar");
    if (bar) bar.style.display = "flex";
  }

  // Google sign-in button — triggers OAuth directly without going through /login
  const googleBtn = document.getElementById("auth-google-btn");
  if (googleBtn) {
    googleBtn.addEventListener("click", async () => {
      googleBtn.textContent = "Redirecting…";
      googleBtn.style.opacity = "0.6";
      googleBtn.style.pointerEvents = "none";
      try {
        const res = await fetch("/api/auth/sign-in/social", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ provider: "google", callbackURL: "/" }),
        });
        const data = await res.json();
        if (data?.url) {
          window.location.href = data.url;
        } else {
          throw new Error("No redirect URL returned");
        }
      } catch {
        googleBtn.textContent = "Sign in with Google";
        googleBtn.style.opacity = "";
        googleBtn.style.pointerEvents = "";
      }
    });
  }

</script>
<script>
  function handleNewConfig(cfg: any) {
    if (!cfg) return;
    if (!cfg.maintenanceMode) {
      window.location.replace("/");
    }
  }

  // Poll config every 30s as a fallback — redirect to / when maintenance is turned off.
  // The worker will then re-evaluate the gate and route to countdown or home.
  const pollInterval = setInterval(async () => {
    try {
      const res = await fetch("/api/config");
      // 503 means still in maintenance — do nothing
      if (res.status === 503) return;
      if (!res.ok) return;
      const json = await res.json();
      handleNewConfig(json?.data);
    } catch {}
  }, 30_000);

  // Real-time updates via WebSocket (exponential backoff on reconnect)
  let wsRetryDelay = 5000;
  function connectWebSocket() {
    const protocol = window.location.protocol === "https:" ? "wss:" : "ws:";
    const ws = new WebSocket(
      `${protocol}//${window.location.host}/api?type=config`,
    );

    ws.onopen = () => { wsRetryDelay = 5000; };

    ws.onmessage = (event) => {
      try {
        const msg = JSON.parse(event.data);
        if (msg.type === "config_update") {
          handleNewConfig(msg.data);
        }
      } catch {}
    };

    ws.onclose = () => {
      setTimeout(connectWebSocket, wsRetryDelay);
      wsRetryDelay = Math.min(wsRetryDelay * 2, 60_000);
    };
  }

  connectWebSocket();

  window.addEventListener("pagehide", () => {
    clearInterval(pollInterval);
  }, { once: true });
</script>
