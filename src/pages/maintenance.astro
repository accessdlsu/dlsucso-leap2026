<Layout title="Maintenance | LEAP 2026" showNavbar={false} noSession={true}>
  <div
    class="mnt-bg"
    style="background:linear-gradient(180deg,#2a2a35 0%,#22222e 10%,#1c1c28 25%,#161622 40%,#0f0f1a 55%,#0a0a14 70%,#07070e 85%,#05050a 100%)"
  >
    {
      fireflies.map((f) => (
        <div
          class="firefly"
          style={{
            left: `${f.x}%`,
            top: `${f.y}%`,
            width: f.size,
            height: f.size,
            animationDelay: `${f.delay}s`,
            animationDuration: `${f.dur}s`,
          }}
        />
      ))
    }
    {
      shapes.map((s) => (
        <div
          class="geo-shape"
          style={{
            left: `${s.x}%`,
            top: `${s.y}%`,
            width: s.size,
            height: s.size,
            animationDelay: `${s.delay}s`,
            animationDuration: `${s.dur}s`,
            borderRadius: s.type === 0 ? "50%" : s.type === 1 ? "4px" : "",
            "--r": `${s.rotation}deg`,
            clipPath:
              s.type === 2
                ? "polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%)"
                : "",
          }}
        />
      ))
    }
    <div class="mnt-content">
      <div class="mnt-icon anim-in" style="opacity:0;transform:translateY(8px)">
        <img
          src="/logo/logo-hd.png"
          alt="LEAP 2026"
          loading="eager"
          style="width: min(500px, 90vw); height: auto; display: block;"
        />
      </div>
      <h1 class="mnt-title anim-in" style="opacity:0;transform:translateY(8px)">
        Under Maintenance
      </h1>
      <p class="mnt-desc anim-in" style="opacity:0;transform:translateY(8px)">
        We're making improvements to serve you better.
      </p>
      <p class="mnt-sub anim-in" style="opacity:0;transform:translateY(8px)">
        Please check back soon.
      </p>
    </div>

    <footer class="mnt-footer" style="position:absolute">
      &copy; LEAP&nbsp;2026 &middot; CSO &middot; DLSU
      <br /><br />
      <span style="opacity:0.5">
        Made by <a href="https://www.facebook.com/accessdlsu" target="_blank" rel="noopener noreferrer" style="pointer-events: auto; color: inherit; text-decoration: underline; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">Association&nbsp;of&nbsp;Computer&nbsp;Engineering&nbsp;Students (ACCESS&nbsp;DLSU)</a>
      </span>
      <br /><br />
    </footer>

    <div class="landscape">
      <svg
        viewBox="0 0 1440 360"
        preserveAspectRatio="xMidYMax slice"
        style="display:block;width:100%;height:100%;"
      >
        <defs>
          <linearGradient id="vG" x1="0%" y1="0%" x2="60%" y2="100%">
            <stop offset="0%" stop-color="#1e1e2a"></stop><stop
              offset="100%"
              stop-color="#0d0d16"></stop>
          </linearGradient>
          <linearGradient id="h3G" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#1a1a26"></stop><stop
              offset="100%"
              stop-color="#0e0e18"></stop>
          </linearGradient>
          <linearGradient id="h2G" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#222230"></stop><stop
              offset="100%"
              stop-color="#12121e"></stop>
          </linearGradient>
          <linearGradient id="h1G" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#262638"></stop><stop
              offset="100%"
              stop-color="#161624"></stop>
          </linearGradient>
          <linearGradient id="gG" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#2e2e3e"></stop><stop
              offset="100%"
              stop-color="#1a1a28"></stop>
          </linearGradient>
          <linearGradient id="fadeG" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#2a2a35" stop-opacity="0"></stop>
            <stop offset="100%" stop-color="#0a0a14" stop-opacity="1"></stop>
          </linearGradient>
        </defs>
        <!-- Central Volcano/Tower -->
        <rect x="650" y="80" width="140" height="280" fill="url(#vG)"></rect>
        <path d="M650 80 L790 80 L790 110 L650 110 Z" fill="rgba(0,0,0,0.12)"
        ></path>
        {
          getRackSlots({ x: 650, w: 140, y: 80 }, 14, 4).map((s) => (
            <g>
              <rect
                x={s.x}
                y={s.y}
                width={s.w}
                height={s.h}
                fill="rgba(255,255,255,0.03)"
              />
              {s.hasLight && (
                <circle
                  cx={s.lightX}
                  cy={s.y + s.h / 2}
                  r="1.5"
                  fill={s.lightColor}
                  opacity="0.6"
                />
              )}
            </g>
          ))
        }

        <!-- Background Layer -->
        {
          bgBuildings.map((b) => (
            <g>
              <rect
                x={b.x}
                y={b.y}
                width={b.w}
                height={360 - b.y}
                fill="url(#h3G)"
              />
              {getRackSlots(b, 12, 3).map((s) => (
                <g>
                  <rect
                    x={s.x}
                    y={s.y}
                    width={s.w}
                    height={s.h}
                    fill="rgba(255,255,255,0.015)"
                  />
                  {s.hasLight && (
                    <circle
                      cx={s.lightX}
                      cy={s.y + s.h / 2}
                      r="1"
                      fill={s.lightColor}
                      opacity="0.25"
                    />
                  )}
                </g>
              ))}
            </g>
          ))
        }

        <!-- Middle Layer -->
        {
          midBuildings.map((b) => (
            <g>
              <rect
                x={b.x}
                y={b.y}
                width={b.w}
                height={360 - b.y}
                fill="url(#h2G)"
              />
              {getRackSlots(b, 10, 3).map((s) => (
                <g>
                  <rect
                    x={s.x}
                    y={s.y}
                    width={s.w}
                    height={s.h}
                    fill="rgba(255,255,255,0.025)"
                  />
                  {s.hasLight && (
                    <circle
                      cx={s.lightX}
                      cy={s.y + s.h / 2}
                      r="1.2"
                      fill={s.lightColor}
                      opacity="0.4"
                    />
                  )}
                </g>
              ))}
            </g>
          ))
        }

        <!-- Foreground Layer -->
        {
          fgBuildings.map((b) => (
            <g>
              <rect
                x={b.x}
                y={b.y}
                width={b.w}
                height={360 - b.y}
                fill="url(#h1G)"
              />
              {getRackSlots(b, 8, 3).map((s) => (
                <g>
                  <rect
                    x={s.x}
                    y={s.y}
                    width={s.w}
                    height={s.h}
                    fill="rgba(255,255,255,0.04)"
                  />
                  {s.hasLight && (
                    <circle
                      cx={s.lightX}
                      cy={s.y + s.h / 2}
                      r="1.5"
                      fill={s.lightColor}
                      opacity="0.75"
                    />
                  )}
                </g>
              ))}
            </g>
          ))
        }

        <rect x="0" y="310" width="1440" height="50" fill="url(#gG)"></rect>
        <rect
          x="0"
          y="330"
          width="1440"
          height="30"
          fill="#1a1a28"
          opacity="0.4"></rect>
        <rect x="0" y="335" width="1440" height="25" fill="url(#fadeG)"></rect>
      </svg>
    </div>
  </div>
</Layout>

