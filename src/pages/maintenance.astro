---
import Layout from '../layouts/Layout.astro';

const fireflies = Array.from({ length: 16 }, (_, i) => ({
  id: i,
  x: (i * 17.3 + (i % 3) * 29) % 94 + 3,
  y: (i * 11.7 + (i % 5) * 13) % 55 + 5,
  size: 2 + (i % 3),
  delay: (i * 0.61) % 7,
  dur: 3.5 + (i % 5) * 0.6,
}));

const shapes = Array.from({ length: 8 }, (_, i) => ({
  id: i,
  x: 5 + (i * 12.5 + (i % 2) * 4) % 90,
  y: 8 + (i * 9.3 + (i % 3) * 7) % 75,
  size: 30 + (i % 4) * 20,
  delay: (i * 1.2) % 6,
  dur: 10 + (i % 3) * 5,
  type: i % 3,
  rotation: (i * 52) % 360,
}));
---

<Layout title="Maintenance — LEAP 2026" showNavbar={false}>
  <div class="mnt-bg" style="background:linear-gradient(180deg,#2a2a35 0%,#22222e 10%,#1c1c28 25%,#161622 40%,#0f0f1a 55%,#0a0a14 70%,#07070e 85%,#05050a 100%)">
    {fireflies.map((f) => (
      <div
        class="firefly"
        style={{
          left: `${f.x}%`,
          top: `${f.y}%`,
          width: f.size,
          height: f.size,
          animationDelay: `${f.delay}s`,
          animationDuration: `${f.dur}s`,
        }}
      />
    ))}
    {shapes.map((s) => (
      <div
        class="geo-shape"
        style={{
          left: `${s.x}%`,
          top: `${s.y}%`,
          width: s.size,
          height: s.size,
          animationDelay: `${s.delay}s`,
          animationDuration: `${s.dur}s`,
          borderRadius: s.type === 0 ? '50%' : s.type === 1 ? '4px' : '',
          '--r': `${s.rotation}deg`,
          clipPath: s.type === 2 ? 'polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%)' : '',
        }}
      />
    ))}
    <div class="mnt-content">
      <div class="mnt-icon anim-in" style="opacity:0;transform:translateY(8px)">
        <img
          src="/logo/logo-hd.png"
          alt="LEAP 2026"
          loading="eager"
          style="width: min(500px, 90vw); height: auto; display: block;"
        />
      </div>
      <h1 class="mnt-title anim-in" style="opacity:0;transform:translateY(8px)">Under Maintenance</h1>
      <p class="mnt-desc anim-in" style="opacity:0;transform:translateY(8px)">We're making improvements to serve you better.</p>
      <p class="mnt-sub anim-in" style="opacity:0;transform:translateY(8px)">Please check back soon.</p>
    </div>

    <footer class="mnt-footer" style="position:absolute">LEAP 2026 &copy; DLSUCSO</footer>

    <div class="landscape">
      <svg viewBox="0 0 1440 360" preserveAspectRatio="xMidYMax slice" style="display:block;width:100%;height:100%;">
        <defs>
          <linearGradient id="vG" x1="0%" y1="0%" x2="60%" y2="100%">
            <stop offset="0%" stop-color="#1e1e2a" /><stop offset="100%" stop-color="#0d0d16" />
          </linearGradient>
          <linearGradient id="h3G" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#1a1a26" /><stop offset="100%" stop-color="#0e0e18" />
          </linearGradient>
          <linearGradient id="h2G" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#222230" /><stop offset="100%" stop-color="#12121e" />
          </linearGradient>
          <linearGradient id="h1G" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#262638" /><stop offset="100%" stop-color="#161624" />
          </linearGradient>
          <linearGradient id="gG" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#2e2e3e" /><stop offset="100%" stop-color="#1a1a28" />
          </linearGradient>
          <linearGradient id="fadeG" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#2a2a35" stop-opacity="0" />
            <stop offset="100%" stop-color="#0a0a14" stop-opacity="1" />
          </linearGradient>
        </defs>
        <path d="M650 360 L650 80 L790 80 L790 360 Z" fill="url(#vG)" />
        <path d="M650 80 L790 80 L790 110 L650 110 Z" fill="rgba(0,0,0,0.12)" />
        <path d="M30 360 L30 270 L100 270 L100 360 Z M150 360 L150 280 L220 280 L220 360 Z M280 360 L280 260 L350 260 L350 360 Z M410 360 L410 275 L480 275 L480 360 Z M530 360 L530 255 L600 255 L600 360 Z M820 360 L820 265 L890 265 L890 360 Z M940 360 L940 285 L1010 285 L1010 360 Z M1070 360 L1070 270 L1140 270 L1140 360 Z M1210 360 L1210 260 L1280 260 L1280 360 Z M1320 360 L1320 280 L1390 280 L1390 360 Z" fill="url(#h3G)" />
        <path d="M10 360 L10 230 L80 230 L80 360 Z M110 360 L110 215 L180 215 L180 360 Z M230 360 L230 225 L300 225 L300 360 Z M350 360 L350 210 L420 210 L420 360 Z M480 360 L480 205 L550 205 L550 360 Z M800 360 L800 220 L870 220 L870 360 Z M910 360 L910 210 L980 210 L980 360 Z M1040 360 L1040 225 L1110 225 L1110 360 Z M1170 360 L1170 215 L1240 215 L1240 360 Z M1290 360 L1290 230 L1360 230 L1360 360 Z" fill="url(#h2G)" />
        <path d="M0 360 L0 200 L70 200 L70 360 Z M100 360 L100 185 L170 185 L170 360 Z M260 360 L260 195 L330 195 L330 360 Z M420 360 L420 175 L490 175 L490 360 Z M560 360 L560 165 L630 165 L630 360 Z M700 360 L700 180 L770 180 L770 360 Z M840 360 L840 170 L910 170 L910 360 Z M980 360 L980 190 L1050 190 L1050 360 Z M1120 360 L1120 175 L1190 175 L1190 360 Z M1280 360 L1280 195 L1350 195 L1350 360 Z" fill="url(#h1G)" />
        <path d="M0 360 L0 310 L1440 310 L1440 360 Z" fill="url(#gG)" />
        <rect x="0" y="330" width="1440" height="30" fill="#1a1a28" opacity="0.4" />
        <rect x="0" y="335" width="1440" height="25" fill="url(#fadeG)" />
      </svg>
    </div>
  </div>
</Layout>

<style>
  @font-face {
    font-family: 'TD-Sulog';
    src: url('/fonts/TD-Sulog.woff2') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  body {
    margin: 0;
    overflow: hidden;
    cursor: url('/salakot_cursor.png'), auto;
    -webkit-user-select: none;
    user-select: none;
  }
  main {
    padding: 0;
  }

  /* ── Background ── */
  .mnt-bg {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100svh;
    overflow: hidden;
    position: relative;
    background: linear-gradient(180deg, #2a2a35 0%, #22222e 10%, #1c1c28 25%, #161622 40%, #0f0f1a 55%, #0a0a14 70%, #07070e 85%, #05050a 100%);
  }
  .mnt-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
  }

  /* ── Content ── */
  .mnt-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.75rem, 2.5vw, 1.25rem);
  }
  .mnt-icon img {
    display: block;
    height: auto;
    filter: drop-shadow(0 0 50px rgba(222, 154, 73, 0.18));
  }

  .mnt-title {
    font-family: 'TD-Sulog', serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 5.5vw, 2.4rem);
    letter-spacing: 0.015em;
    line-height: 1.15;
    text-align: center;
    margin-top: -0.5rem;
    background: linear-gradient(180deg, #fff5c4 0%, #fae185 35%, #de9a49 75%, #b07820 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: 0 2px 0 rgba(80,40,10,0.4), 0 4px 24px rgba(0,0,0,0.55), 0 0 48px rgba(222,154,73,0.4), 0 0 96px rgba(250,225,133,0.2);
    filter: drop-shadow(0 3px 12px rgba(0,0,0,0.5)) drop-shadow(0 0 24px rgba(222,154,73,0.35));
  }

  .mnt-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.85rem, 2vw, 1rem);
    color: rgba(255,255,255,0.6);
    text-align: center;
    line-height: 1.5;
    margin: 0.25rem 0 0;
    letter-spacing: 0.04em;
    max-width: 360px;
  }

  .mnt-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.8rem, 2vw, 0.95rem);
    color: rgba(255,255,255,0.45);
    text-align: center;
    line-height: 1.5;
    margin: 0.25rem 0 0;
    letter-spacing: 0.06em;
  }

  /* ── Entrance Animation ── */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .anim-in {
    animation: fadeInUp 0.35s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
  }

  /* ── Landscape ── */
  .landscape {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 55%;
    z-index: 1;
    pointer-events: none;
    line-height: 0;
  }

  /* ── Fireflies ── */
  .firefly {
    position: absolute;
    border-radius: 50%;
    background: #fae185;
    will-change: opacity;
    box-shadow: 0 0 6px 4px rgba(250, 225, 133, 0.5);
    pointer-events: none;
    z-index: 3;
    animation: fireflyBlink 4s ease-in-out infinite;
  }

  @keyframes fireflyBlink {
    0%, 100% { opacity: 0.06; }
    50% { opacity: 0.7; }
  }

  /* ── Geometric Shapes ── */
  .geo-shape {
    position: absolute;
    border: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.015);
    pointer-events: none;
    z-index: 1;
    animation: shapeFloat 12s ease-in-out infinite;
  }

  @keyframes shapeFloat {
    0%, 100% { transform: translateY(0) rotate(var(--r, 0deg)); opacity: 0.15; }
    33% { transform: translateY(-12px) rotate(calc(var(--r, 0deg) + 8deg)); opacity: 0.3; }
    66% { transform: translateY(6px) rotate(calc(var(--r, 0deg) - 4deg)); opacity: 0.2; }
  }

  /* ── Footer ── */
  .mnt-footer {
    position: absolute;
    bottom: 1rem;
    left: 0;
    right: 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.68rem;
    color: rgba(255,255,255,0.3);
    text-align: center;
    letter-spacing: 0.06em;
    z-index: 2;
    pointer-events: none;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .landscape {
      height: 35%;
    }
    .mnt-desc {
      max-width: 80vw;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .firefly { animation: none; opacity: 0.3; }
    .geo-shape { display: none; }
    .anim-in { animation: none; opacity: 1; transform: none; }
  }
</style>
