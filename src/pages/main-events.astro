---
import Layout from "../layouts/Layout.astro";
import FeaturedEvents from "../components/FeaturedEvents";
import Footer from "../components/navigation/Footer.astro";
import "../styles/gallery-card.css";
---

<Layout title="Main Events | LEAP 2026" description="Discover the featured main events of LEAP 2026.">
  <div class="events-bg">
    <div class="events-content">
      <h1 class="events-title">Main Events</h1>
      <p class="events-desc">
        Discover the spotlight events that make LEAP&nbsp;2026 an unforgettable
        celebration. These main events are not to be missed.
      </p>
      <FeaturedEvents client:only="react" />
      <div class="events-cta">
        <p class="events-cta-text">
          Want to see all workshops and sessions?
        </p>
        <a href="/classes" class="events-cta-btn">Browse All Classes</a>
      </div>
      <Footer />
    </div>
  </div>
</Layout>

<style is:global>
  @keyframes faqSpin {
    to { transform: rotate(360deg); }
  }

  /* Featured events grid using ClassCard */
  .featured-cards-grid {
    width: 100%;
    max-width: 1040px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(260px, 100%), 1fr));
    gap: 1.25rem;
  }

  .featured-cards-grid .gallery-card {
    flex: none;
    width: 100%;
    aspect-ratio: 1080 / 1350;
  }

  /* Drawer/dialog — exact copy from classes page */
  .drawer-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    animation: overlayIn 0.25s ease;
  }

  @keyframes overlayIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .drawer {
    width: 100%;
    max-width: 100%;
    max-height: 85svh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 24px 24px 0 0;
    box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.2);
    animation: drawerUp 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    margin: 0 1rem;
  }

  @media (max-width: 768px) {
    .drawer { margin: 0; border-radius: 20px 20px 0 0; }
  }

  @keyframes drawerUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }

  @media (min-width: 769px) {
    .drawer-overlay { align-items: center; }
    .drawer {
      max-width: 560px;
      border-radius: 24px;
      margin: 0;
      animation: modalIn 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }
    @keyframes modalIn {
      from { transform: scale(0.92) translateY(20px); opacity: 0; }
      to { transform: scale(1) translateY(0); opacity: 1; }
    }
  }

  .drawer-close {
    position: absolute;
    top: 0.75rem; right: 0.75rem; z-index: 2;
    width: 36px; height: 36px; border-radius: 50%; border: none;
    background: rgba(0,0,0,0.4); color: #fff; font-size: 1.4rem; line-height: 1;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
  }
  .drawer-close:hover { background: rgba(0,0,0,0.6); }

  .drawer-hero {
    flex-shrink: 0; display: flex; flex-direction: row;
    border-bottom: 1px solid rgba(255,255,255,0.06); max-height: 52vh;
  }
  .drawer-poster {
    flex: 0 0 42%; max-width: 42%; padding: 10px 0 10px 10px;
    background: transparent; display: flex; align-items: stretch;
    justify-content: center; box-sizing: border-box;
  }
  .drawer-poster img {
    width: 100%; height: 100%; object-fit: cover;
    object-position: center top; display: block; border-radius: 14px; overflow: hidden;
  }
  .drawer-poster-placeholder {
    width: 100%; height: 100%; background: rgba(255,255,255,0.03); border-radius: 14px;
  }
  .drawer-header {
    flex: 1 1 0; min-width: 0; padding: 1rem 1.25rem 1rem;
    display: flex; flex-direction: column; gap: 0.5rem; overflow: hidden;
  }
  .drawer-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .drawer-title {
    font-family: 'TD-Sulog', serif; font-size: 1.45rem; font-weight: 700;
    color: #fff; margin: 0; line-height: 1.2;
    overflow: hidden; text-overflow: ellipsis;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  }

  .drawer-body {
    flex: 1 1 auto; overflow-y: auto; overflow-x: hidden;
    overscroll-behavior: contain; padding: 1rem 1.5rem;
    display: flex; flex-direction: column; gap: 0.85rem;
    scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.15) transparent;
  }
  .drawer-body::-webkit-scrollbar { width: 4px; }
  .drawer-body::-webkit-scrollbar-track { background: transparent; }
  .drawer-body::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 9999px; }
  .drawer-body::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.3); }

  .drawer-meta {
    display: flex; flex-direction: column; gap: 0.5rem;
    padding: 1rem; background: rgba(255,255,255,0.04); border-radius: 12px;
  }
  .drawer-meta-row {
    display: flex; justify-content: space-between; align-items: baseline;
    gap: 0.5rem; font-family: 'DM Sans', sans-serif; font-size: 0.82rem;
  }
  .drawer-meta-label { color: rgba(255,255,255,0.35); font-weight: 600; letter-spacing: 0.05em; flex-shrink: 0; }
  .drawer-meta-val { color: rgba(255,255,255,0.75); font-weight: 500; text-align: right; word-break: break-word; }
  .drawer-desc { font-family: 'DM Sans', sans-serif; font-size: 0.85rem; color: rgba(255,255,255,0.55); line-height: 1.6; margin: 0; }

  .drawer-footer { flex-shrink: 0; padding: 0.85rem 1.5rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.06); }

  .drawer-bookmark-btn {
    flex-shrink: 0; width: 44px; height: 44px; border-radius: 9999px;
    border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.65); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s, color 0.2s, border-color 0.2s; padding: 0;
  }
  .drawer-bookmark-btn:hover { background: rgba(255,255,255,0.12); color: #fff; border-color: rgba(255,255,255,0.25); }
  .drawer-bookmark-btn:disabled { opacity: 0.45; cursor: not-allowed; }

  .drawer-enroll {
    font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 700;
    padding: 0.75rem 1.5rem; border-radius: 9999px; border: none;
    background: linear-gradient(135deg, #4a7a5a 0%, #2a5a3a 100%);
    color: #fff; cursor: pointer; transition: all 0.2s;
    width: 100%; box-sizing: border-box; display: block;
    text-align: center; text-decoration: none;
  }
  .drawer-enroll:hover { background: linear-gradient(135deg, #568c68 0%, #346e44 100%); transform: translateY(-1px); }

  .class-theme-tag {
    font-family: 'Poppins', sans-serif; font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.05em; padding: 0.25rem 0.6rem; border-radius: 6px;
    background: rgba(222,154,73,0.15); color: #fae185; border: 1px solid rgba(222,154,73,0.2);
  }
  .class-day-tag {
    font-family: 'Poppins', sans-serif; font-size: 0.6rem; font-weight: 600;
    padding: 0.25rem 0.6rem; border-radius: 6px;
    background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.1);
  }

  @media (max-width: 540px) {
    .drawer-poster { flex: 0 0 38%; max-width: 38%; }
    .drawer-header { padding: 0.75rem 2rem 0.75rem 0.75rem; }
    .drawer-title { font-size: 1rem; -webkit-line-clamp: 3; }
  }
</style>

<style>
  body {
    margin: 0;
  }
  main {
    padding: 0;
  }

  .events-bg {
    min-height: 100svh;
    overflow-y: auto;
    overflow-x: clip;
    position: relative;
    scrollbar-width: none;
    background: linear-gradient(
      180deg,
      #1a2940 0%,
      #1d3148 8%,
      #1f3a4c 18%,
      #234048 28%,
      #284240 38%,
      #2c4338 48%,
      #2e4632 58%,
      #314830 68%,
      #344932 78%,
      #3a4a35 86%,
      #4a4a3a 94%,
      #5a4838 100%
    );
  }
  .events-bg::-webkit-scrollbar {
    display: none;
  }

  .events-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: calc(1.5rem + var(--nav-space-top)) 1.5rem
      calc(2rem + var(--nav-space-bottom));
    min-height: 100svh;
    box-sizing: border-box;
  }

  .events-title {
    font-family: "TD-Sulog", serif;
    font-weight: 700;
    font-size: clamp(2.5rem, 7vh, 4.5rem);
    color: #fff;
    margin: 0 0 1.5rem;
    line-height: 1.1;
    text-align: center;
    letter-spacing: 0.015em;
    line-height: 1.15;
    margin: 0 0 0.25rem;
    padding-left: 0.15em;
    background: linear-gradient(
      180deg,
      #fff5c4 0%,
      #fae185 35%,
      #de9a49 75%,
      #b07820 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 3px 12px rgba(0, 0, 0, 0.5));
  }

  .events-desc {
    font-family: "DM Sans", sans-serif;
    font-size: clamp(0.9rem, 2vh, 1.2rem);
    color: rgba(255, 255, 255, 0.65);
    text-align: center;
    line-height: 1.6;
    margin: 0 0 2.5rem;
    max-width: 600px;
  }

  .events-cta {
    width: 100%;
    max-width: 600px;
    margin-top: 3rem;
    padding: 2rem;
    background: rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .events-cta-text {
    font-family: "DM Sans", sans-serif;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    line-height: 1.5;
  }

  .events-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 2rem;
    font-family: "DM Sans", sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, #4a7a5a 0%, #2a5a3a 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.2s ease,
      background 0.2s ease;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .events-cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.3);
    background: linear-gradient(135deg, #568c68 0%, #346e44 100%);
  }



  @media (max-width: 768px) {
    .events-content {
      padding: calc(1rem + var(--nav-space-top)) 1rem
        calc(2rem + var(--nav-space-bottom));
    }
  }
</style>
