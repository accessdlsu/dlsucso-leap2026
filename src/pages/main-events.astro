---
import Layout from "../layouts/Layout.astro";
import FeaturedEvents from "../components/FeaturedEvents";
import Footer from "../components/navigation/Footer.astro";
import "../styles/gallery-card.css";
---

<Layout title="Main Events | LEAP 2026" description="Discover the featured main events of LEAP 2026.">
  <div class="events-bg">
    <div class="events-content">
      <h1 class="events-title" transition:name="page-title">Main Events</h1>
      <p class="events-desc">
        Discover the spotlight events that make LEAP&nbsp;2026 an unforgettable
        celebration. These main events are not to be missed.
      </p>
      <FeaturedEvents client:only="react">
        <div slot="fallback" class="featured-cards-grid" aria-label="Loading events" role="status">
          {Array.from({ length: 4 }, () => (
            <div class="skeleton-card">
              <div class="skeleton skeleton-card-img" />
              <div class="skeleton skeleton-card-badge" />
              <div class="skeleton skeleton-card-logo" />
              <div class="skeleton-card-body">
                <div class="skeleton skeleton-card-tag" />
                <div class="skeleton skeleton-card-title" />
                <div class="skeleton skeleton-card-info" />
                <div class="skeleton-card-footer">
                  <div class="skeleton skeleton-card-badge-sm" />
                  <div class="skeleton skeleton-card-btn" />
                </div>
              </div>
            </div>
          ))}
        </div>
      </FeaturedEvents>
      <div class="events-cta">
        <p class="events-cta-text">
          Want to see all workshops and sessions?
        </p>
        <a href="/classes" class="events-cta-btn">Browse All Classes</a>
      </div>
      <Footer />
    </div>
  </div>
</Layout>

<style is:global>
  @keyframes faqSpin {
    to { transform: rotate(360deg); }
  }

  /* Featured events grid using ClassCard */
  .featured-cards-grid {
    width: 100%;
    max-width: 1040px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(260px, 100%), 1fr));
    gap: 1.25rem;
    justify-content: center;
  }

  .featured-cards-grid .gallery-card {
    flex: none;
    width: 100%;
    aspect-ratio: 1080 / 1350;
  }

</style>

<style>
  body {
    margin: 0;
  }
  main {
    padding: 0;
  }

  .events-bg {
    min-height: 100svh;
    overflow-y: auto;
    overflow-x: clip;
    position: relative;
    scrollbar-width: none;
    background: linear-gradient(
      180deg,
      #1a2940 0%,
      #1d3148 8%,
      #1f3a4c 18%,
      #234048 28%,
      #284240 38%,
      #2c4338 48%,
      #2e4632 58%,
      #314830 68%,
      #344932 78%,
      #3a4a35 86%,
      #4a4a3a 94%,
      #5a4838 100%
    );
  }
  .events-bg::-webkit-scrollbar {
    display: none;
  }

  .events-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: calc(1.5rem + var(--nav-space-top)) 1.5rem
      calc(2rem + var(--nav-space-bottom));
    min-height: 100svh;
    box-sizing: border-box;
  }

  .events-title {
    font-family: "TD-Sulog", serif;
    font-weight: 700;
    font-size: clamp(2.5rem, 7vh, 4.5rem);
    color: #fff;
    margin: 0 0 1.5rem;
    line-height: 1.1;
    text-align: center;
    letter-spacing: 0.015em;
    line-height: 1.15;
    margin: 0 0 0.25rem;
    padding-left: 0.15em;
    background: linear-gradient(
      180deg,
      #fff5c4 0%,
      #fae185 35%,
      #de9a49 75%,
      #b07820 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 3px 12px rgba(0, 0, 0, 0.5));
  }

  .events-desc {
    font-family: "DM Sans", sans-serif;
    font-size: clamp(0.9rem, 2vh, 1.2rem);
    color: rgba(255, 255, 255, 0.65);
    text-align: center;
    line-height: 1.6;
    margin: 0 0 2.5rem;
    max-width: 600px;
  }

  .events-cta {
    width: 100%;
    max-width: 600px;
    margin-top: 3rem;
    padding: 2rem;
    background: rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .events-cta-text {
    font-family: "DM Sans", sans-serif;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    line-height: 1.5;
  }

  .events-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 2rem;
    font-family: "DM Sans", sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, #4a7a5a 0%, #2a5a3a 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 0.2s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.2s ease,
      background 0.2s ease;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .events-cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.3);
    background: linear-gradient(135deg, #568c68 0%, #346e44 100%);
  }



  @media (max-width: 768px) {
    .events-content {
      padding: calc(1rem + var(--nav-space-top)) 1rem
        calc(2rem + var(--nav-space-bottom));
    }
  }
</style>
