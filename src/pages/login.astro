---
import Layout from "../layouts/Layout.astro";
import Fireflies from "../components/Fireflies.astro";
---

<Layout title="Login | LEAP 2026" showNavbar={false} noSession={true}>
  <div class="login-bg">
    <Fireflies />
    <!-- Custom Premium Toast -->
    <div class="toast-container" id="login-toast" role="alert">
      <span class="toast-icon">
        <svg
          viewBox="0 0 24 24"
          width="16"
          height="16"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
      </span>
      <span class="toast-text" id="toast-message"></span>
    </div>

    <div class="login-content">
      <div
        class="logo-wrapper anim-in"
      >
        <img
          src="/logo/logo-hd.png"
          alt="LEAP 2026"
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          style="width: min(500px, 90vw); height: auto; display: block;"
        />
      </div>
      <span class="tagline anim-in"
        >Isang Nayon, Isang Layunin</span
      >
      <button
        class="gsi-material-button anim-in"
        id="google-signin-btn"
      >
        <div class="gsi-material-button-state"></div>
        <div class="gsi-material-button-content-wrapper">
          <div class="gsi-material-button-icon">
            <svg
              version="1.1"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 48 48"
              xmlns:xlink="http://www.w3.org/1999/xlink"
              style="display: block;"
            >
              <path
                fill="#EA4335"
                d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"
              ></path>
              <path
                fill="#4285F4"
                d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"
              ></path>
              <path
                fill="#FBBC05"
                d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"
              ></path>
              <path
                fill="#34A853"
                d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"
              ></path>
              <path fill="none" d="M0 0h48v48H0z"></path>
            </svg>
          </div>
          <span class="gsi-material-button-contents">Sign in with Google</span>
          <span style="display: none;">Sign in with Google</span>
        </div>
        <div class="spinner" aria-hidden="true"></div>
      </button>
      <p class="terms anim-in">
        By clicking continue, you agree to our{" "}
        <a href="#" data-dialog="tos">Terms of Service</a> and{" "}
        <a href="#" data-dialog="pp">Privacy Policy</a>.
      </p>
    </div>

    <footer class="login-footer" style="position:absolute">
      &copy; LEAP 2026 &middot; CSO &middot; DLSU
    </footer>

    <dialog class="legal-dialog" id="legal-dialog">
      <div class="legal-dialog-content">
        <button class="legal-dialog-close" id="dialog-close" aria-label="Close"
          >&times;</button
        >
        <h2 id="dialog-title"></h2>
        <p id="dialog-body"></p>
      </div>
    </dialog>

    <div class="landscape">
      <svg
        viewBox="0 0 1440 360"
        preserveAspectRatio="xMidYMax slice"
        style="display:block;width:100%;height:100%;"
      >
        <defs>
          <linearGradient id="vG" x1="0%" y1="0%" x2="60%" y2="100%">
            <stop offset="0%" stop-color="#1a3520"></stop><stop
              offset="100%"
              stop-color="#0d1e10"></stop>
          </linearGradient>
          <linearGradient id="h3G" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#193825"></stop><stop
              offset="100%"
              stop-color="#0f2018"></stop>
          </linearGradient>
          <linearGradient id="h2G" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#1e4a2c"></stop><stop
              offset="100%"
              stop-color="#12271a"></stop>
          </linearGradient>
          <linearGradient id="h1G" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#245630"></stop><stop
              offset="100%"
              stop-color="#152e1c"></stop>
          </linearGradient>
          <linearGradient id="gG" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#2a6234"></stop><stop
              offset="100%"
              stop-color="#1a3a20"></stop>
          </linearGradient>
          <linearGradient id="fadeG" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#1a2940" stop-opacity="0"></stop>
            <stop offset="100%" stop-color="#3a4a35" stop-opacity="1"></stop>
          </linearGradient>
        </defs>
        <path d="M900 0 L710 200 L1090 200 Z" fill="url(#vG)"></path>
        <path d="M900 0 L1090 200 L1020 200 Z" fill="rgba(0,0,0,0.12)"></path>
        <path
          d="M0 170 Q150 130 310 150 Q430 165 550 145 Q620 132 710 200 L0 200 Z"
          fill="url(#h3G)"></path>
        <path
          d="M1090 200 Q1170 130 1280 122 Q1360 115 1440 140 L1440 200 Z"
          fill="url(#h3G)"></path>
        <path
          d="M0 200 Q130 170 280 184 Q430 200 560 174 Q680 150 800 180 Q920 210 1060 178 Q1180 150 1310 180 Q1390 196 1440 186 L1440 360 L0 360 Z"
          fill="url(#h2G)"></path>
        <path
          d="M0 250 Q130 225 300 238 Q460 252 620 228 Q760 205 900 234 Q1050 264 1200 238 Q1330 215 1440 234 L1440 360 L0 360 Z"
          fill="url(#h1G)"></path>
        <path
          d="M0 280 C160 262 320 308 540 280 C760 252 960 304 1180 276 C1340 258 1420 290 1440 282 L1440 360 L0 360 Z"
          fill="url(#gG)"></path>
        <path
          d="M0 300 C200 284 400 320 600 298 C800 276 1000 316 1200 294 C1340 280 1410 308 1440 300 L1440 360 L0 360 Z"
          fill="#1a3a20"
          opacity="0.55"></path>
        <rect x="0" y="335" width="1440" height="25" fill="url(#fadeG)"></rect>
      </svg>
    </div>
  </div>
</Layout>

<style>
  @font-face {
    font-family: "TD-Sulog";
    src: url("/fonts/TD-Sulog.woff2") format("woff2");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  body {
    margin: 0;
    overflow: hidden;
    cursor: url("/assets/cursor.png"), auto;
    -webkit-user-select: none;
    user-select: none;
  }
  main {
    padding: 0;
  }

  /* ── Background ── */
  .login-bg {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100dvh;
    overflow: hidden;
    position: relative;
    background: linear-gradient(
      180deg,
      #1a2940 0%,
      #1d3148 8%,
      #1f3a4c 18%,
      #234048 28%,
      #284240 38%,
      #2c4338 48%,
      #2e4632 58%,
      #314830 68%,
      #344932 78%,
      #3a4a35 86%,
      #4a4a3a 94%,
      #5a4838 100%
    );
  }

  /* ── Content ── */
  .login-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.75rem, 2.5vw, 1.25rem);
  }
  .login-content .logo-wrapper img {
    filter: drop-shadow(0 0 50px rgba(222, 154, 73, 0.18));
  }
  .tagline {
    margin-top: -0.5rem;
    font-family: "TD-Sulog", serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 5.5vw, 2.4rem);
    letter-spacing: 0.015em;
    line-height: 1.15;
    text-align: center;
    background: linear-gradient(
      180deg,
      #fff5c4 0%,
      #fae185 35%,
      #de9a49 75%,
      #b07820 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow:
      0 2px 0 rgba(80, 40, 10, 0.4),
      0 4px 24px rgba(0, 0, 0, 0.55),
      0 0 48px rgba(222, 154, 73, 0.4),
      0 0 96px rgba(250, 225, 133, 0.2);
    filter: drop-shadow(0 3px 12px rgba(0, 0, 0, 0.5))
      drop-shadow(0 0 24px rgba(222, 154, 73, 0.35));
  }

  .anim-in { /* animations removed for performance */ }

  /* ── Landscape ── */
  .landscape {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 55%;
    z-index: 1;
    pointer-events: none;
    line-height: 0;
  }

  /* ── Custom Premium Toast ── */
  .toast-container {
    position: fixed;
    top: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(-20px);
    z-index: 10002;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    background: rgba(185, 28, 28, 0.35); /* red glassmorphism */
    backdrop-filter: blur(20px);
    border: 1px solid rgba(239, 68, 68, 0.4); /* soft red border */
    border-radius: 20px; /* robust corner radius that looks clean when wrapped */
    font-family: "DM Sans", sans-serif;
    font-size: 0.82rem;
    color: #fff;
    box-shadow:
      0 16px 36px rgba(185, 28, 28, 0.15),
      0 8px 16px rgba(0, 0, 0, 0.2);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.3s;
    box-sizing: border-box;
    max-width: min(600px, calc(100% - 48px));
    width: auto;
  }
  .toast-container.visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  .toast-icon {
    display: inline-flex;
    align-items: center;
    align-self: flex-start; /* keep aligned to top if text wraps */
    margin-top: 2px;
    color: #fee2e2; /* light contrast warning indicator */
    flex-shrink: 0;
  }
  .toast-text {
    line-height: 1.4;
    white-space: normal; /* wrap text on narrow viewports */
    word-break: break-word;
  }

  /* ── Google Sign-In Button ── */
  .gsi-material-button {
    position: relative;
    margin-top: 1.25rem;
    -moz-user-select: none;
    -webkit-user-select: none;
    -ms-user-select: none;
    -webkit-appearance: none;
    background-color: WHITE;
    background-image: none;
    border: 1px solid #747775;
    -webkit-border-radius: 20px;
    border-radius: 20px;
    -webkit-box-sizing: border-box;
    box-sizing: border-box;
    color: #1f1f1f;
    cursor: pointer;
    font-family: "Google Sans", arial, sans-serif;
    font-size: 14px;
    height: 40px;
    letter-spacing: 0.25px;
    outline: none;
    overflow: hidden;
    padding: 0 12px;
    text-align: center;
    -webkit-transition:
      background-color 0.218s,
      border-color 0.218s,
      box-shadow 0.218s;
    transition:
      background-color 0.218s,
      border-color 0.218s,
      box-shadow 0.218s;
    vertical-align: middle;
    white-space: nowrap;
    width: auto;
    max-width: 400px;
    min-width: min-content;
  }

  .gsi-material-button .gsi-material-button-icon {
    height: 20px;
    margin-right: 10px;
    min-width: 20px;
    width: 20px;
  }

  .gsi-material-button .gsi-material-button-content-wrapper {
    -webkit-align-items: center;
    align-items: center;
    display: flex;
    -webkit-flex-direction: row;
    flex-direction: row;
    -webkit-flex-wrap: nowrap;
    flex-wrap: nowrap;
    height: 100%;
    justify-content: space-between;
    position: relative;
    width: 100%;
  }

  .gsi-material-button .gsi-material-button-contents {
    -webkit-flex-grow: 1;
    flex-grow: 1;
    font-family: "Google Sans", arial, sans-serif;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    vertical-align: top;
  }

  .gsi-material-button .gsi-material-button-state {
    -webkit-transition: opacity 0.218s;
    transition: opacity 0.218s;
    bottom: 0;
    left: 0;
    opacity: 0;
    position: absolute;
    right: 0;
    top: 0;
  }

  .gsi-material-button:disabled {
    cursor: default;
    background-color: #ffffff61;
    border-color: #1f1f1f1f;
  }
  .gsi-material-button:disabled .gsi-material-button-contents {
    opacity: 38%;
  }
  .gsi-material-button:disabled .gsi-material-button-icon {
    opacity: 38%;
  }

  .gsi-material-button:not(:disabled):active .gsi-material-button-state,
  .gsi-material-button:not(:disabled):focus .gsi-material-button-state {
    background-color: #303030;
    opacity: 12%;
  }

  .gsi-material-button:not(:disabled):hover {
    -webkit-box-shadow:
      0 1px 2px 0 rgba(60, 64, 67, 0.3),
      0 1px 3px 1px rgba(60, 64, 67, 0.15);
    box-shadow:
      0 1px 2px 0 rgba(60, 64, 67, 0.3),
      0 1px 3px 1px rgba(60, 64, 67, 0.15);
  }

  .gsi-material-button:not(:disabled):hover .gsi-material-button-state {
    background-color: #303030;
    opacity: 8%;
  }

  /* ── Loading Spinner ── */
  .gsi-material-button.loading .gsi-material-button-content-wrapper {
    visibility: hidden;
  }
  .gsi-material-button.loading .spinner {
    display: block;
  }

  .spinner {
    display: none;
    width: 20px;
    height: 20px;
    border: 2.5px solid #747775;
    border-top-color: transparent;
    border-radius: 50%;
    animation: spin 0.65s linear infinite;
    position: absolute;
    top: 50%;
    left: 50%;
    margin: -10px 0 0 -10px;
    box-sizing: border-box;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* ── Terms Text ── */
  .terms {
    margin: 1rem 0 0;
    font-family: "DM Sans", sans-serif;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.55);
    text-align: center;
    max-width: 260px;
    line-height: 1.45;
  }
  .terms a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(255, 255, 255, 0.3);
    transition:
      color 0.2s,
      text-decoration-color 0.2s;
    cursor: url("/assets/cursor.png"), pointer;
  }
  .terms a:hover {
    color: #fff;
    text-decoration-color: rgba(255, 255, 255, 0.7);
  }

  /* ── Footer ── */
  .login-footer {
    position: absolute;
    bottom: 1rem;
    left: 0;
    right: 0;
    font-family: "DM Sans", sans-serif;
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
    letter-spacing: 0.06em;
    z-index: 2;
    pointer-events: none;
  }

  /* ── Legal Dialog ── */
  .legal-dialog {
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    padding: 0;
    max-width: 480px;
    width: 90vw;
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    cursor: url("/assets/cursor.png"), auto;
  }
  .legal-dialog::backdrop {
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }
  .legal-dialog-content {
    padding: 2rem;
    position: relative;
  }
  .legal-dialog-content h2 {
    font-family: "DM Sans", sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.95);
    margin: 0 0 1rem;
    padding-right: 2rem;
  }
  .legal-dialog-content p {
    font-family: "DM Sans", sans-serif;
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
  }
  .legal-dialog-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    color: rgba(255, 255, 255, 0.55);
    cursor: url("/assets/cursor.png"), pointer;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition:
      background 0.2s,
      color 0.2s;
    padding: 0;
    line-height: 1;
  }
  .legal-dialog-close:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }

  /* ── Privacy Policy Cards ── */
  .pp-subtitle {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.45);
    margin-top: -0.75rem;
    margin-bottom: 1rem;
    font-family: "DM Sans", sans-serif;
  }
  .pp-intro {
    font-size: 0.85rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 1.25rem;
    font-family: "DM Sans", sans-serif;
  }
  .pp-intro strong {
    color: #fff;
    font-weight: 600;
  }
  .pp-cards {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 1.25rem;
    text-align: left;
  }
  .pp-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    transition: background 0.2s, border-color 0.2s;
  }
  .pp-card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.09);
  }
  .pp-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    color: rgba(255, 255, 255, 0.85);
    flex-shrink: 0;
  }
  .pp-card-content {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .pp-card-content h3 {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.95);
    font-family: "DM Sans", sans-serif;
  }
  .pp-card-content p {
    margin: 0 !important;
    font-size: 0.78rem !important;
    line-height: 1.4 !important;
    color: rgba(255, 255, 255, 0.55) !important;
  }
  .pp-footer {
    font-size: 0.75rem !important;
    line-height: 1.45 !important;
    color: rgba(255, 255, 255, 0.45) !important;
    margin-top: 1rem !important;
    font-family: "DM Sans", sans-serif;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .landscape {
      height: 35%;
    }
    .toast-container {
      width: calc(100% - 48px);
      max-width: 360px;
    }
    .tagline {
      max-width: 85vw;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .anim-in {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import {
    createLeapifyAuthClient,
    signInWithGoogleRedirect,
  } from "leapify/client";

  const btn = document.getElementById("google-signin-btn");
  const toast = document.getElementById("login-toast");
  const toastMsg = document.getElementById("toast-message");
  const dialog = document.getElementById("legal-dialog");
  const dialogTitle = document.getElementById("dialog-title");
  const dialogBody = document.getElementById("dialog-body");
  const dialogClose = document.getElementById("dialog-close");
  let toastTimeout: any = null;

  const authClient = createLeapifyAuthClient(window.location.origin);

  const legalCopy = {
    tos: {
      title: "Terms of Service",
      body: `By using LEAP 2026, you agree to comply with the policies and regulations set forth by the De La Salle University Council of Student Organizations (DLSU-CSO). You are responsible for maintaining the confidentiality of your account credentials and for all activities that occur under your account. LEAP 2026 reserves the right to modify or terminate the service at any time without prior notice. Continued use of the platform constitutes acceptance of any such changes.`,
    },
    pp: {
      title: "Privacy Policy",
      body: `
        <div class="pp-cards">
          <div class="pp-card">
            <div class="pp-card-icon">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div class="pp-card-content">
              <h3>Data Privacy Agreement</h3>
              <p>In compliance with the <strong>Data Privacy Act of 2012</strong> (R.A. 10173), DLSU-CSO collects your name, email, and student ID solely for event registration, scheduling, and communication. We secure your records, never share them with third parties without consent, and honor data access/deletion requests sent to DLSU-CSO.</p>
            </div>
          </div>
        </div>
        <p class="pp-footer">By clicking continue, you acknowledge that your information will be processed in accordance with these terms.</p>
      `,
    },
  };

  btn.addEventListener("click", async () => {
    if (btn.disabled) return;

    btn.classList.add("loading");
    btn.disabled = true;

    if (toastTimeout) {
      clearTimeout(toastTimeout);
    }
    toast.classList.remove("visible");

    try {
      // Redirect to root route (homepage) post-OAuth redirect session verification
      await signInWithGoogleRedirect(authClient, window.location.origin + "/");
    } catch (err) {
      btn.classList.remove("loading");
      btn.disabled = false;
      const isGated =
        err instanceof Error && err.message.includes("GATE_ACTIVE");
      toastMsg.textContent = isGated
        ? "Sign-in is not available yet. The site isn't open to students yet."
        : err instanceof Error
          ? err.message
          : "Google sign-in failed. Please try again.";
      toast.classList.add("visible");

      toastTimeout = setTimeout(() => {
        toast.classList.remove("visible");
        toastTimeout = null;
      }, 4000);
    }
  });

  document.querySelectorAll("[data-dialog]").forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const type = link.getAttribute("data-dialog");
      const copy = legalCopy[type];
      if (copy) {
        dialogTitle.textContent = copy.title;
        dialogBody.innerHTML = copy.body;
        dialog.showModal();
      }
    });
  });

  dialogClose.addEventListener("click", () => dialog.close());

  dialog.addEventListener("click", (e) => {
    if (e.target === dialog) dialog.close();
  });

</script>
