---
import Layout from '../layouts/Layout.astro';
import GalleryCarousel from '../components/GalleryCarousel';
import StatsSection from '../components/StatsSection';
import Footer from '../components/navigation/Footer.astro';
import Fireflies from '../components/Fireflies.astro';
import { LEAP_DAYS } from '../constants/leapDays';

// Map LEAP_DAYS to the display format used on homepage
// (removing year from date for homepage display)
const days = LEAP_DAYS.map(day => ({
  num: day.num,
  label: day.label,
  date: day.date.replace(', 2026', ''), // Convert "June 19, 2026" → "June 19"
  weekday: day.weekday,
  mode: day.mode,
}));

const themes = [
  { slug: 'palayan-ng-karunungan', name: 'Palayan ng Karunungan', img: '/images/themes/palay.png', color: '#c8e6a0' },
  { slug: 'pamilihan-ng-kakayahan', name: 'Pamilihan ng Kakayahan', img: '/images/themes/pamilihan.png', color: '#ffb68c' },
  { slug: 'plaza-ng-malikhaing-diwa', name: 'Plaza ng Malikhaing Diwa', img: '/images/themes/plaza.png', color: '#a0d4f0' },
  { slug: 'dambana-ng-pagkakaisa', name: 'Dambana ng Pagkakaisa', img: '/images/themes/dambana.png', color: '#d4a0e8' },
  { slug: 'palaisdaan-ng-kalusugan', name: 'Palaisdaan ng Kalusugan', img: '/images/themes/palaisdaan.png', color: '#80d4b0' },
  { slug: 'bahay-ng-bayanihan', name: 'Bahay ng Bayanihan', img: '/images/themes/bahay.png', color: '#f0c080' },
];
---

<Layout title="LEAP 2026" description="De La Salle University CSO LEAP 2026: Isang Nayon, Isang Layunin.">
  <div class="home-bg">
    <Fireflies />

    <!-- Sidebar Scroll-Snap Dots -->
    <div class="scroll-indicator">
      <button class="indicator-dot active" data-target="hero-section" aria-label="Go to Hero Section"></button>
      <button class="indicator-dot" data-target="featured-section" aria-label="Go to Featured Section"></button>
      <button class="indicator-dot" data-target="classes-section" aria-label="Go to Classes Section"></button>
      <button class="indicator-dot" data-target="subthemes" aria-label="Go to Subthemes Section"></button>
      <button class="indicator-dot" data-target="leapdays" aria-label="Go to LEAP Days Section"></button>
    </div>

    <div class="home-hero" id="hero-section">
      <div class="home-content">
        <div class="logo-wrapper anim-in">
          <img
            src="/logo/logo-hd.png"
            alt="LEAP 2026"
            loading="eager"
            style="width: min(600px, 85vw, 50vh); height: auto; max-height: 50vh; object-fit: contain; display: block;"
            draggable="false"
          />
        </div>
        <span class="tagline anim-in">Isang Nayon, Isang Layunin</span>
      </div>
      <div class="scroll-cue anim-in">
        <span class="scroll-cue-text">Scroll Down</span>
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </div>
    </div>

    <section class="home-featured" id="featured-section">
      <h2 class="featured-title">Main Events</h2>
      <p class="featured-desc">Discover what makes LEAP 2026 a celebration of community, culture, and shared purpose.</p>
      <GalleryCarousel client:only="react" />
    </section>

    <section class="home-classes" id="classes-section">
      <StatsSection client:only="react" subthemeCount={themes.length} dayCount={days.length} />
    </section>

    <section class="home-subthemes" id="subthemes">
      <h2 class="section-title">Subthemes</h2>
      <p class="section-desc">Explore the six pillars of LEAP 2026 — each representing a unique facet of community and growth.</p>
      <div class="subthemes-scroll">
        <div class="subthemes-grid">
          {themes.map((t) => (
            <a href={`/classes?theme=${t.slug}`} class="subtheme-card">
              <div class="subtheme-img-wrap">
                <img src={t.img} alt={t.name} loading="lazy" />
              </div>
              <span class="subtheme-name" style={`color:${t.color}`}>{t.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="home-leapdays" id="leapdays">
      <h2 class="section-title">LEAP Days</h2>
      <p class="section-desc">Six days of celebration, learning, and community — pick your day.</p>
      <div class="leapdays-row">
        {days.map((d) => (
          <a href={`/classes?day=${d.num}`} class={`leapday-card ${d.mode.includes('Off-Campus') ? 'off-campus' : ''} ${d.mode.includes('until') ? 'limited' : ''}`}>
            <span class="leapday-num">{d.label}</span>
            <span class="leapday-date">{d.date}</span>
            <span class="leapday-weekday">{d.weekday}</span>
            <span class="leapday-mode">{d.mode}</span>
          </a>
        ))}
      </div>
      <Footer />
    </section>

    <div class="landscape">
      <svg viewBox="0 0 1440 360" preserveAspectRatio="xMidYMax slice" style="display:block;width:100%;height:100%;">
        <defs>
          <linearGradient id="vG" x1="0%" y1="0%" x2="60%" y2="100%">
            <stop offset="0%" stop-color="#1a3520" /><stop offset="100%" stop-color="#0d1e10" />
          </linearGradient>
          <linearGradient id="h3G" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#193825" /><stop offset="100%" stop-color="#0f2018" />
          </linearGradient>
          <linearGradient id="h2G" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#1e4a2c" /><stop offset="100%" stop-color="#12271a" />
          </linearGradient>
          <linearGradient id="h1G" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#245630" /><stop offset="100%" stop-color="#152e1c" />
          </linearGradient>
          <linearGradient id="gG" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#2a6234" /><stop offset="100%" stop-color="#1a3a20" />
          </linearGradient>
          <linearGradient id="fadeG" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#1a2940" stop-opacity="0" />
            <stop offset="100%" stop-color="#3a4a35" stop-opacity="1" />
          </linearGradient>
        </defs>
        <path d="M900 0 L710 200 L1090 200 Z" fill="url(#vG)" />
        <path d="M900 0 L1090 200 L1020 200 Z" fill="rgba(0,0,0,0.12)" />
        <path d="M0 170 Q150 130 310 150 Q430 165 550 145 Q620 132 710 200 L0 200 Z" fill="url(#h3G)" />
        <path d="M1090 200 Q1170 130 1280 122 Q1360 115 1440 140 L1440 200 Z" fill="url(#h3G)" />
        <path d="M0 200 Q130 170 280 184 Q430 200 560 174 Q680 150 800 180 Q920 210 1060 178 Q1180 150 1310 180 Q1390 196 1440 186 L1440 360 L0 360 Z" fill="url(#h2G)" />
        <path d="M0 250 Q130 225 300 238 Q460 252 620 228 Q760 205 900 234 Q1050 264 1200 238 Q1330 215 1440 234 L1440 360 L0 360 Z" fill="url(#h1G)" />
        <path d="M0 280 C160 262 320 308 540 280 C760 252 960 304 1180 276 C1340 258 1420 290 1440 282 L1440 360 L0 360 Z" fill="url(#gG)" />
        <path d="M0 300 C200 284 400 320 600 298 C800 276 1000 316 1200 294 C1340 280 1410 308 1440 300 L1440 360 L0 360 Z" fill="#1a3a20" opacity="0.55" />
        <rect x="0" y="335" width="1440" height="25" fill="url(#fadeG)" />
      </svg>
    </div>
  </div>
</Layout>

<style>
  @font-face {
    font-family: 'TD-Sulog';
    src: url('/fonts/TD-Sulog.woff2') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  body {
    margin: 0;
    overflow: hidden;
    -webkit-user-select: none;
    user-select: none;
    background-color: #0d1e10;
  }
  main {
    padding: 0;
  }

  /* ── Background ── */
  .home-bg {
    height: 100dvh;
    overflow-y: auto;
    overflow-x: clip;
    position: relative;
    scrollbar-width: none;
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
    background: linear-gradient(180deg, #1a2940 0%, #1d3148 8%, #1f3a4c 18%, #234048 28%, #284240 38%, #2c4338 48%, #2e4632 58%, #314830 68%, #344932 78%, #3a4a35 86%, #4a4a3a 94%, #5a4838 100%);
  }
  .home-bg::-webkit-scrollbar {
    display: none;
  }

  /* ── Hero (first viewport) ── */
  .home-hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    position: relative;
    z-index: 2;
    scroll-snap-align: start;
    box-sizing: border-box;
    padding: max(1rem, 3vh) max(1rem, 3vw);
  }

  /* ── Content ── */
  .home-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.5rem, 3vh, 1.25rem);
    max-width: min(520px, 90vw);
    padding: 0;
    transition: opacity 0.3s ease-out, transform 0.3s ease-out;
    box-sizing: border-box;
  }
  .home-content .logo-wrapper img {
    filter: drop-shadow(0 0 50px rgba(222, 154, 73, 0.18));
    user-select: none;
    -webkit-user-select: none;
    -webkit-user-drag: none;
  }
  .home-content.scroll-hide {
    opacity: 0;
    transform: translateY(-12px);
    pointer-events: none;
  }

  @media (min-width: 969px) and (min-height: 500px) {
    .home-content {
      margin-top: -44px;
    }
  }

  .tagline {
    margin-top: clamp(-0.5rem, -1.5vh, 0rem);
    font-family: 'TD-Sulog', serif;
    font-weight: 700;
    font-size: clamp(1.2rem, 5vmin, 2.4rem);
    letter-spacing: 0.015em;
    line-height: 1.15;
    text-align: center;
    background: linear-gradient(180deg, #fff5c4 0%, #fae185 35%, #de9a49 75%, #b07820 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: 0 2px 0 rgba(80,40,10,0.4), 0 4px 24px rgba(0,0,0,0.55), 0 0 48px rgba(222,154,73,0.4), 0 0 96px rgba(250,225,133,0.2);
    filter: drop-shadow(0 3px 12px rgba(0,0,0,0.5)) drop-shadow(0 0 24px rgba(222,154,73,0.35));
  }

  .home-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.85rem, 2vw, 1rem);
    color: rgba(255,255,255,0.65);
    text-align: center;
    line-height: 1.6;
    letter-spacing: 0.02em;
    margin: 0.25rem 0 0;
    max-width: 460px;
  }

  /* ── CTA Buttons ── */
  .home-cta {
    display: flex;
    gap: 1rem;
    margin: 0.75rem 0 0;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 2rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: #fff;
    background: linear-gradient(135deg, #4a7a5a 0%, #2a5a3a 100%);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 30px;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0,0,0,0.35);
    background: linear-gradient(135deg, #568c68 0%, #346e44 100%);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 2rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 30px;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .btn-secondary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0,0,0,0.25);
    background: rgba(255,255,255,0.14);
    color: #fff;
  }

  .anim-in {
    animation: fadeInUp 0.35s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }
  .anim-in:nth-child(2) { animation-delay: 0.15s; }
  .anim-in:nth-child(3) { animation-delay: 0.2s; }
  .anim-in:nth-child(4) { animation-delay: 0.25s; }

  /* ── Landscape ── */
  .landscape {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 55%;
    z-index: 1;
    pointer-events: none;
    line-height: 0;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease;
  }
  .landscape.scroll-hide {
    opacity: 0;
    transform: translateY(40px);
  }

  /* ── Subthemes Section ── */
  .home-subthemes {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: calc(1.5rem + var(--nav-space-top)) 1.5rem calc(1.5rem + var(--nav-space-bottom));
    text-align: center;
    min-height: 100dvh;
    box-sizing: border-box;
    scroll-snap-align: start;
  }

  .subthemes-scroll {
    width: 100%;
    max-width: 1100px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 3rem 0 4rem;
    box-sizing: border-box;
  }
  .subthemes-scroll::-webkit-scrollbar { display: none; }

  .subthemes-grid {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .subtheme-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    cursor: pointer;
    flex: 0 0 140px;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .subtheme-card:hover {
    transform: scale(1.2);
  }

  .subtheme-card:nth-child(odd) {
    margin-top: -1.5rem;
  }

  .subtheme-card:nth-child(even) {
    margin-top: 1.5rem;
  }



  .subtheme-img-wrap {
    width: 100%;
    height: 140px;
    line-height: 0;
    transition: box-shadow 0.3s ease;
    border-radius: 4px;
  }

  .subtheme-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
  }

  @keyframes wiggle {
    0%, 100% { transform: rotate(0deg); }
    20% { transform: rotate(-7deg); }
    40% { transform: rotate(5deg); }
    60% { transform: rotate(-3deg); }
    80% { transform: rotate(2deg); }
  }

  .subtheme-card:hover .subtheme-img-wrap {
    animation: wiggle 0.5s ease;
  }

  .subtheme-card:hover .subtheme-name {
    color: #fff;
  }

  .subtheme-name {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(0.7rem, 1.8vw, 0.95rem);
    line-height: 1.3;
    letter-spacing: 0.02em;
    text-align: center;
    transition: color 0.2s ease;
  }

  .section-title,
  .featured-title {
    margin: 0 0 0.2rem;
    font-family: 'TD-Sulog', serif;
    font-weight: 700;
    font-size: clamp(2.6rem, 6.5vw, 4.5rem);
    letter-spacing: 0.015em;
    line-height: 1.15;
    white-space: nowrap;
    background: linear-gradient(180deg, #fff5c4 0%, #fae185 35%, #de9a49 75%, #b07820 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: 0 2px 0 rgba(80,40,10,0.4), 0 4px 24px rgba(0,0,0,0.55), 0 0 48px rgba(222,154,73,0.4), 0 0 96px rgba(250,225,133,0.2);
    filter: drop-shadow(0 3px 12px rgba(0,0,0,0.5)) drop-shadow(0 0 24px rgba(222,154,73,0.35));
  }

  .section-desc,
  .featured-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.8rem, 2.2vw, 1.2rem);
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    letter-spacing: 0.02em;
    margin: 0.3rem 1.5rem 1rem;
    max-width: 640px;
  }

  /* ── LEAP Days Section ── */
  .home-leapdays {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: calc(1.5rem + var(--nav-space-top)) 1.5rem calc(1.5rem + var(--nav-space-bottom));
    text-align: center;
    min-height: 100dvh;
    box-sizing: border-box;
    scroll-snap-align: start;
  }

  .leapdays-row {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.75rem;
    width: 100%;
    max-width: 900px;
  }

  .leapday-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 1rem 0.5rem;
    text-decoration: none;
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    cursor: pointer;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  }

  .leapday-card:hover {
    transform: scale(1.08);
    box-shadow: 0 0 24px rgba(222,154,73,0.3), 0 0 48px rgba(250,225,133,0.1);
  }

  .leapday-num {
    font-family: 'TD-Sulog', serif;
    font-weight: 700;
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    background: linear-gradient(180deg, #fff5c4 0%, #fae185 35%, #de9a49 75%, #b07820 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.2;
  }

  .leapday-date {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.65rem, 1.4vw, 0.8rem);
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.05em;
  }

  .leapday-weekday {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.55rem, 1.2vw, 0.7rem);
    font-weight: 500;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .leapday-mode {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.5rem, 1.1vw, 0.68rem);
    font-weight: 600;
    color: rgba(250,225,133,0.65);
    letter-spacing: 0.03em;
  }

  /* ── Featured Section ── */
  .home-featured {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: calc(1.5rem + var(--nav-space-top)) 1.5rem calc(1.5rem + var(--nav-space-bottom));
    text-align: center;
    min-height: 100dvh;
    justify-content: center;
    box-sizing: border-box;
    scroll-snap-align: start;
  }



  /* ── Classes / Stats Section ── */
  .home-classes {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: calc(1.5rem + var(--nav-space-top)) 1.5rem calc(1.5rem + var(--nav-space-bottom));
    min-height: 100dvh;
    box-sizing: border-box;
    scroll-snap-align: start;
  }




  /* ── Responsive ── */
  @media (max-width: 968px) {
    .landscape {
      height: 35%;
    }
    .home-cta {
      flex-direction: column;
      align-items: center;
    }
    .btn-primary, .btn-secondary {
      width: 100%;
      max-width: 280px;
    }
    .subthemes-scroll {
      padding: 1.5rem 0 2rem;
      overflow: visible;
    }
    .subthemes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }
    .subtheme-card {
      flex: none;
      margin-top: 0 !important;
    }
    .subtheme-card:hover {
      transform: scale(1.08);
    }
    .section-desc,
    .featured-desc {
      font-size: 0.85rem;
      margin: 0 1rem 0.75rem;
    }
    .subtheme-img-wrap {
      height: 100px;
    }
    .subtheme-name {
      font-size: 0.75rem;
    }
    .home-subthemes {
      padding: 1rem 1rem 2rem;
    }
    .home-leapdays {
      padding: 1rem 1rem 2rem;
    }
    .leapdays-row {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.4rem;
    }
    .leapday-card:hover {
      transform: scale(1.04);
    }
    .leapday-card {
      padding: 0.6rem 0.3rem;
    }
  }

  /* ── Scroll Cue ── */
  .scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: 0;
    right: 0;
    margin: 0 auto;
    width: max-content;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.45);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    pointer-events: none;
    z-index: 1001;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  @media (max-width: 968px) {
    .scroll-cue {
      bottom: 5.5rem;
    }
  }
  .scroll-cue.scroll-hide {
    opacity: 0;
    transform: translateY(15px);
  }
  .scroll-cue svg {
