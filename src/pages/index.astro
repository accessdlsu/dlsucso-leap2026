<script is:inline>
(() => {
  const bg = document.querySelector('.home-bg');
  const content = document.querySelector('.home-content');
  const landscape = document.querySelector('.landscape');
  const cue = document.querySelector('.scroll-cue');
  const dots = document.querySelectorAll('.indicator-dot');
  
  if (!bg) return;

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Dot navigation click handler
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const targetId = dot.getAttribute('data-target');
      const target = document.getElementById(targetId);
      if (target) {
        bg.scrollTo({
          top: target.offsetTop,
          behavior: 'smooth'
        });
      }
    });
  });

  // Section IntersectionObserver for active dot (root = scroll container)
  const sectionIds = ['hero-section', 'featured-section', 'classes-section', 'subthemes', 'leapdays'];
  const sectionRatios = new Map<string, number>(sectionIds.map(id => [id, 0]));
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        sectionRatios.set(entry.target.id, entry.intersectionRatio);
      });
      // Pick the section with the highest intersection ratio
      let bestId = '';
      let bestRatio = 0;
      sectionRatios.forEach((ratio, id) => {
        if (ratio > bestRatio) { bestRatio = ratio; bestId = id; }
      });
      if (bestId && bestRatio > 0) {
        const idx = sectionIds.indexOf(bestId);
        if (idx !== -1) dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      }
    },
    { root: bg, threshold: [0, 0.25, 0.5, 0.75, 1] }
  );
  sectionIds.forEach(id => {
    const el = document.getElementById(id);
    if (el) sectionObserver.observe(el);
  });

  /* ── Hero scroll listener (hide/show hero elements only) ── */
  bg.addEventListener('scroll', () => {
    const st = bg.scrollTop;
    if (!reduced) {
      if (st > 80) {
        if (content) content.classList.add('scroll-hide');
        if (landscape) landscape.classList.add('scroll-hide');
        if (cue) cue.classList.add('scroll-hide');
      } else {
        if (content) content.classList.remove('scroll-hide');
        if (landscape) landscape.classList.remove('scroll-hide');
        if (cue) cue.classList.remove('scroll-hide');
      }
    }
  }, { passive: true });
})();
</script>

