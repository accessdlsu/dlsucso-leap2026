---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/navigation/Footer.astro";
---

<link rel="preload" as="image" href="/assets/background.jpeg" fetchpriority="high" />
<Layout title="Overview | LEAP 2026" description="Learn about LEAP 2026 — a week-long celebration of community, culture, and shared purpose at De La Salle University.">
  <div class="about-bg">
    <div class="about-content">
      <div class="about-logo-wrapper">
        <img
          src="/logo/logo-hd.png"
          alt="LEAP 2026"
          loading="eager"
          style="width: min(420px, 80vw); height: auto; display: block;"
        />
      </div>
      <span class="about-tagline">Isang Nayon, Isang Layunin</span>
      <h1 class="about-title">About Us</h1>
      <p class="about-desc" style="margin-bottom: 1.25rem;">
        LEAP 2026: Isang Nayon, Isang Layunin is derived from the Lasallian value of service, emphasizing that growth and success are achieved through collaboration, empathy, and a shared commitment to the common good. LEAP 2026 encourages Lasallians to contribute their strengths, support one another, and recognize that meaningful learning happens when individuals work together toward a common purpose.
      </p>
      <p class="about-desc">
        Guided by the value of service, LEAP 2026 reminds students that leadership is about uplifting others, education is a gift meant to be shared, and true development comes from choosing community over competition. Through active participation and cooperation, Lasallians are called to build a stronger, more united community that reflects the values of bayanihan and collective growth.
      </p>


      <Footer />
    </div>
  </div>
</Layout>

<style>
  body {
    margin: 0;
  }
  main {
    padding: 0;
  }

  .about-bg {
    min-height: 100dvh;
    position: relative;
    background: linear-gradient(rgba(10, 18, 30, 0.75), rgba(10, 18, 30, 0.75)), url('/assets/background.jpeg') no-repeat center center;
    background-size: cover;
  }
 
  .about-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: calc(1.5rem + var(--nav-space-top)) 1.5rem
      calc(1rem + var(--nav-space-bottom));
    min-height: 100dvh;
    box-sizing: border-box;
  }

  @font-face {
    font-family: "TD-Sulog";
    src: url("/fonts/TD-Sulog.woff2") format("woff2");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  .about-logo-wrapper {
    margin-bottom: 0.25rem;
    filter: drop-shadow(0 0 50px rgba(222, 154, 73, 0.18));
  }

  .about-tagline {
    font-family: "TD-Sulog", serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 5.5vw, 2.4rem);
    letter-spacing: 0.015em;
    line-height: 1.15;
    text-align: center;
    margin-bottom: 1rem;
    background: linear-gradient(
      180deg,
      #fff5c4 0%,
      #fae185 35%,
      #de9a49 75%,
      #b07820 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 3px 12px rgba(0, 0, 0, 0.5))
      drop-shadow(0 0 24px rgba(222, 154, 73, 0.35));
  }

  .about-title {
    font-family: "TD-Sulog", serif;
    font-weight: 700;
    font-size: clamp(2.5rem, 7vh, 4.5rem);
    color: #fff;
    margin: 0 0 1.5rem;
    line-height: 1.1;
    text-align: center;
    filter: drop-shadow(0 3px 12px rgba(0, 0, 0, 0.5));
  }

  .about-desc {
    font-family: "DM Sans", sans-serif;
    font-size: clamp(0.9rem, 2vh, 1.2rem);
    color: rgba(255, 255, 255, 0.65);
    text-align: center;
    line-height: 1.7;
    margin: 0 0 2.5rem;
    max-width: 640px;
  }
  .about-desc em {
    color: rgba(250, 225, 133, 0.8);
    font-style: italic;
  }

  /* ── Cards ── */
  .about-card {
    width: 100%;
    max-width: 640px;
    padding: 1.75rem 2rem;
    margin-bottom: 1rem;
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    transition:
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    box-sizing: border-box;
  }
  .about-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
  }

  .about-card-title {
    font-family: "TD-Sulog", serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .about-card-text {
    font-family: "DM Sans", sans-serif;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin: 0;
  }



  /* ── Core Values / Lists Grid ── */




  @media (max-width: 768px) {
    .about-content {
      padding: calc(1rem + var(--nav-space-top)) 1rem
        calc(1rem + var(--nav-space-bottom));
    }
    .about-card {
      padding: 1.25rem 1.5rem;
    }
  }
</style>
